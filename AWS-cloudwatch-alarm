# Alarm for EACH EKS Pod NAMESPACE - CPU

aws cloudwatch put-metric-alarm \
  --alarm-name "EKS-CPU-High-<namespace>" \
  --alarm-description "High CPU usage for namespace <namespace>" \
  --namespace "ContainerInsights" \
  --metric-name "pod_cpu_utilization_over_pod_limit" \
  --dimensions Name=ClusterName,Value=<cluster-name> Name=Namespace,Value=<namespace> Name=LaunchType,Value=fargate \
  --statistic Average \
  --period 300 \
  --threshold 70 \
  --comparison-operator GreaterThanThreshold \
  --evaluation-periods 1 \
  --treat-missing-data missing \
  --alarm-actions <SNS-arn>

